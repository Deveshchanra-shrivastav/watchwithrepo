@model WatchWith.Models.RegisterDto
@{ ViewData["Title"] = "Create account"; }
<div class="auth-page">
  <div class="auth-card">
    <a href="/" class="auth-logo">
      <div class="logo-dot" style="width:28px;height:28px;border-radius:8px;"><svg width="11" height="11" viewBox="0 0 11 11" fill="white"><polygon points="2,1 10,5.5 2,10"/></svg></div>
      WatchWith
    </a>
    <h2>Create your account</h2>
    <p class="auth-sub">Start watching together in seconds</p>
    @if (!ViewData.ModelState.IsValid) {
      <div class="alert-error-dark">@foreach(var e in ViewData.ModelState.Values.SelectMany(v=>v.Errors)){<div>@e.ErrorMessage</div>}</div>
    }
    <form method="post" action="/Account/Register">
      <div class="field"><label>Display name</label><input type="text" name="DisplayName" placeholder="e.g. Aryan" required autocomplete="name"/></div>
      <div class="field"><label>Email</label><input type="email" name="Email" placeholder="you@example.com" required autocomplete="email"/></div>
      <div class="field"><label>Password <span class="hint">(min 6 chars + a number)</span></label><input type="password" name="Password" placeholder="••••••••" required autocomplete="new-password"/></div>
      <button type="submit" style="width:100%;padding:12px;border-radius:11px;background:linear-gradient(135deg,#6C63FF,#8B5CF6);color:#fff;border:none;font-size:14px;font-weight:600;cursor:pointer;">Create account →</button>
    </form>
    <div class="auth-footer">Already have an account? <a href="/Account/Login">Sign in</a></div>
  </div>
</div>
