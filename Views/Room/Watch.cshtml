        function addFile(e) {
            var f = e.target.files[0];
            if (!f) return;

            // Step 1: Play locally immediately — instant, no upload needed
            var local = URL.createObjectURL(f);
            loadVideo(local, "url", 0);

            // Step 2: Show upload progress UI
            document.getElementById("uploadFileName").textContent = f.name;
            document.getElementById("uploadProgressWrap").style.display = "block";
            document.getElementById("uploadDropText").textContent = "Uploading...";
            document.getElementById("uploadStatus").textContent = "Watching locally. Uploading so others can join...";
            document.getElementById("uploadBar").style.width = "0%";
            document.getElementById("uploadPct").textContent = "0%";

            // Step 3: Upload to server using XHR — no timeout, stream to disk
            var fd = new FormData();
            fd.append("file", f);

            var xhr = new XMLHttpRequest();
            xhr.open("POST", "/Video/Upload", true);

            // NO timeout — let it run as long as needed
            xhr.timeout = 0;

            xhr.upload.onprogress = function(ev) {
                if (ev.lengthComputable) {
                    var pct = Math.round((ev.loaded / ev.total) * 100);
                    document.getElementById("uploadBar").style.width  = pct + "%";
                    document.getElementById("uploadPct").textContent  = pct + "%";
                    var mb = Math.round(ev.loaded / 1048576);
                    var total = Math.round(ev.total / 1048576);
                    document.getElementById("uploadStatus").textContent =
                        "Uploading " + mb + " MB / " + total + " MB (" + pct + "%) — watching locally";
                }
            };

            xhr.onload = function() {
                if (xhr.status === 200) {
                    try {
                        var res = JSON.parse(xhr.responseText);
                        // Switch local player to server URL so seeking works for all users
                        var v = document.getElementById("mp4Player");
                        var currentT = v ? v.currentTime : 0;
                        if (v && res.url) { v.src = res.url; v.currentTime = currentT; }
                        // Broadcast server URL to all room members
                        safeInvoke("SetVideo", ROOM_ID, res.url, "url");
                        document.getElementById("uploadStatus").textContent = "Upload complete! Room synced.";
                        document.getElementById("uploadDropText").textContent = "Click to choose a video file";
                        document.getElementById("uploadBar").style.width = "100%";
                        setTimeout(function() {
                            document.getElementById("uploadProgressWrap").style.display = "none";
                            document.getElementById("uploadBar").style.width = "0%";
                            closeModal();
                        }, 2500);
                    } catch(ex) {
                        document.getElementById("uploadStatus").textContent = "Upload done — playing locally only";
                        closeModal();
                    }
                } else {
                    document.getElementById("uploadStatus").textContent =
                        "Upload failed (" + xhr.status + ") — playing locally only";
                    console.error("Upload error:", xhr.status, xhr.responseText);
                    setTimeout(function() { closeModal(); }, 3000);
                }
            };

            xhr.onerror = function() {
                document.getElementById("uploadStatus").textContent =
                    "Connection error — video plays locally only";
                console.error("XHR network error during upload");
                setTimeout(function() { closeModal(); }, 3000);
            };

            xhr.ontimeout = function() {
                document.getElementById("uploadStatus").textContent = "Upload timed out — playing locally";
                setTimeout(function() { closeModal(); }, 3000);
            };

            xhr.send(fd);
        }

// ── Voice Chat (WebRTC) ───────────────────────────────────────
async function toggleMic() {
  micMuted = !micMuted;
  var btn   = document.getElementById("micBtn");
  var label = document.getElementById("micLabel");

  if (!micMuted) {
    // Unmute — get mic
    try {
      localStream = await navigator.mediaDevices.getUserMedia({ audio:true, video:false });
      localStream.getAudioTracks()[0].enabled = true;
      btn.className   = "voice-btn speaking";
      label.textContent = "Mute";
      document.getElementById("micIcon").textContent = "🔴";
      document.getElementById("voiceHint").textContent = "You are speaking";

      // Audio ducking — lower video volume when speaking
      isSomeonespeaking = true;
      applyVolume(Math.max(10, videoVolume * 0.25));

      // Offer peer connection to each online member
      membersData.filter(function(m){ return m.isOnline && m.userId !== USER_ID; }).forEach(function(m) {
        createOffer(m.userId);
      });

      safeInvoke("SetVoiceState", ROOM_ID, false);
    } catch(err) {
      alert("Microphone access denied. Please allow mic access in your browser.");
      micMuted = true;
    }
  } else {
    // Mute
    if (localStream) {
      localStream.getTracks().forEach(function(t){ t.stop(); });
      localStream = null;
    }
    btn.className = "voice-btn muted";
    label.textContent = "Unmute";
    document.getElementById("micIcon").textContent = "🎙️";
    document.getElementById("voiceHint").textContent = "Click to speak";
    isSomeonespeaking = false;
    applyVolume(videoVolume);
    safeInvoke("SetVoiceState", ROOM_ID, true);
  }
}

function onVoiceStateChanged(state) {
  // Another user changed their voice state
  var vav = document.getElementById("vav_" + state.userId);
  if (vav) {
    if (!state.muted) {
      vav.classList.add("speaking");
      // Duck video volume when someone else speaks
      isSomeonespeaking = true;
      applyVolume(Math.max(10, videoVolume * 0.25));
      showSync(state.userName + " is speaking 🎙️");
    } else {
      vav.classList.remove("speaking");
      // Check if anyone else is still speaking
      var anySpeaking = Array.from(document.querySelectorAll(".voice-av.speaking")).length > 0;
      if (!anySpeaking && micMuted) {
        isSomeonespeaking = false;
        applyVolume(videoVolume);
      }
    }
  }
}

// WebRTC signaling
async function createOffer(targetUserId) {
  var pc = new RTCPeerConnection({ iceServers: [{ urls:"stun:stun.l.google.com:19302" }] });
  peerConnections[targetUserId] = pc;

  if (localStream) localStream.getTracks().forEach(function(t){ pc.addTrack(t, localStream); });

  pc.ontrack = function(e) { playRemoteAudio(targetUserId, e.streams[0]); };
  pc.onicecandidate = function(e) {
    if (e.candidate) safeInvoke("VoiceIceCandidate", targetUserId, JSON.stringify(e.candidate));
  };

  var offer = await pc.createOffer();
  await pc.setLocalDescription(offer);
  safeInvoke("VoiceOffer", ROOM_ID, targetUserId, JSON.stringify(offer));
}

async function onVoiceOffer(data) {
  var pc = new RTCPeerConnection({ iceServers: [{ urls:"stun:stun.l.google.com:19302" }] });
  peerConnections[data.fromUserId] = pc;

  if (localStream) localStream.getTracks().forEach(function(t){ pc.addTrack(t, localStream); });
  pc.ontrack = function(e) { playRemoteAudio(data.fromUserId, e.streams[0]); };
  pc.onicecandidate = function(e) {
    if (e.candidate) safeInvoke("VoiceIceCandidate", data.fromUserId, JSON.stringify(e.candidate));
  };

  await pc.setRemoteDescription(JSON.parse(data.offer));
  var answer = await pc.createAnswer();
  await pc.setLocalDescription(answer);
  safeInvoke("VoiceAnswer", data.fromUserId, JSON.stringify(answer));
}

async function onVoiceAnswer(data) {
  var pc = peerConnections[data.fromUserId];
  if (pc) await pc.setRemoteDescription(JSON.parse(data.answer));
}

async function onVoiceIce(data) {
  var pc = peerConnections[data.fromUserId];
  if (pc) { try { await pc.addIceCandidate(JSON.parse(data.candidate)); } catch(e){} }
}

function playRemoteAudio(userId, stream) {
  var existing = document.getElementById("audio_" + userId);
  if (existing) existing.remove();
  var audio = document.createElement("audio");
  audio.id       = "audio_" + userId;
  audio.autoplay = true;
  audio.srcObject = stream;
  document.body.appendChild(audio);
}

