function browserGo(rawUrl) {
  var url = rawUrl.trim();
  if (!url) return;
  if (!url.startsWith("http://") && !url.startsWith("https://")) {
    // Treat as Google search
    url = "https://www.google.com/search?q=" + encodeURIComponent(url) + "&igu=1";
  }
  loadFrame(url);
  safeInvoke("BrowserNavigate", ROOM_ID, url);
}

