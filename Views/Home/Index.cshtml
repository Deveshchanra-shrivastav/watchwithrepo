@{ ViewData["Title"] = "WatchWith"; }
<div class="landing">
  <nav class="landing-nav">
    <div class="landing-logo">
      <div class="logo-dot"><svg width="12" height="12" viewBox="0 0 12 12" fill="white"><polygon points="2,1 10,6 2,11"/></svg></div>
      WatchWith
    </div>
    <div style="display:flex;gap:8px;">
      <a href="/Account/Login" style="padding:7px 16px;border-radius:9px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,.18);font-size:13px;cursor:pointer;text-decoration:none;">Log in</a>
      <a href="/Account/Register" style="padding:7px 16px;border-radius:9px;background:linear-gradient(135deg,#6C63FF,#8B5CF6);color:#fff;border:none;font-size:13px;font-weight:500;text-decoration:none;">Get started</a>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-badge">Watch · Chat · Voice · Co-browse together</div>
    <h1>Your favourite videos,<br/><span>shared with loved ones</span></h1>
    <p>Stream YouTube, upload videos, voice chat, and browse the web together — all in perfect sync with end-to-end encrypted messaging.</p>
    <div class="hero-btns">
      <a href="/Account/Register" class="hero-btn-p">Create a free room →</a>
      <a href="/Account/Login" class="hero-btn-g" style="display:inline-block;padding:13px 30px;border-radius:12px;background:transparent;color:#fff;border:1px solid rgba(255,255,255,.2);font-size:15px;text-decoration:none;">Sign in</a>
    </div>
    <div class="stats-row">
      <div class="stat"><strong>🔒</strong><span>E2E Encrypted</span></div>
      <div class="stat-sep" style="height:36px;"></div>
      <div class="stat"><strong>🎙️</strong><span>Voice chat</span></div>
      <div class="stat-sep" style="height:36px;"></div>
      <div class="stat"><strong>🌐</strong><span>Co-browse</span></div>
      <div class="stat-sep" style="height:36px;"></div>
      <div class="stat"><strong style="color:#FAC775;">Free</strong><span>To start</span></div>
    </div>
  </div>
  <div class="features">
    <div class="feat"><div class="feat-icon">▶</div><div class="feat-title">Perfect sync</div><div class="feat-desc">Play, pause, rewind — instantly mirrored for everyone in the room.</div></div>
    <div class="feat" style="border-color:rgba(108,99,255,.3);background:rgba(108,99,255,.08);"><div class="feat-icon">🎙️</div><div class="feat-title">Voice chat</div><div class="feat-desc">Unmute to speak. Video volume ducks automatically so everyone hears you.</div></div>
    <div class="feat" style="border-color:rgba(67,214,165,.2);"><div class="feat-icon">💬</div><div class="feat-title">Encrypted chat</div><div class="feat-desc">WhatsApp-style 1-on-1 and group messaging with AES-256 encryption.</div></div>
    <div class="feat"><div class="feat-icon">🌐</div><div class="feat-title">Co-browse</div><div class="feat-desc">Open a shared browser — everyone sees the same page in real time.</div></div>
  </div>
</div>
